# --- LLM Provider (OpenAI/LongCat/etc) ---
# Default is OpenAI. If using LongCat, change BASE_URL and MODEL.
OPENAI_API_KEY="ak_2yp3Xw1Ny7ky2pF7er9x93ZO9jj6G"
OPENAI_BASE_URL="https://api.longcat.chat/openai"
OPENAI_LLM_MODEL="LongCat-Flash-Lite"

# --- Infrastructure ---
REDIS_URL="redis://localhost:6379/0"
VECTOR_DB_TYPE="chroma"             # "chroma" or "qdrant"
CHROMA_PERSIST_DIR="./chroma_db"
QDRANT_URL="http://localhost:6333"

# --- Local Models (Requires [full] installation) ---
# Set these to "true" to load local models into memory
LOAD_LOCAL_LLM=false
LOAD_LOCAL_VLM=false
LOCAL_LLM_TEXT_MODEL="Qwen/Qwen2-1.5B-Instruct"
LOCAL_VLM_MODEL="Qwen/Qwen2-VL-2B-Instruct"

# --- RAG & Search ---
RAG_QUERY_EXPANSION=true
RAG_HYDE_ENABLED=true
RAG_MMR_ENABLED=true
RAG_MAX_CONTEXT_CHUNKS=5

# --- Security ---
SECURITY_MAX_INPUT_LENGTH=4096
SECURITY_ENABLE_HALLUCINATION_CHECK=false
